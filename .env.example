# ============================================================
# AUTH SERVICE — Variables de entorno
# ============================================================
# Copia este archivo: cp .env.example .env
# Completa todos los valores marcados con <COMPLETAR>
# El archivo .env está en .gitignore — NUNCA lo subas al repo
#
# CÓMO CARGAR LAS VARIABLES:
#   Docker:    docker run --env-file .env ...
#   IntelliJ:  Run/Debug Configurations → EnvFile → selecciona .env
#   Shell:     export $(grep -v '^#' .env | xargs) && mvn spring-boot:run
# ============================================================


# ------------------------------------------------------------
# PERFIL DE SPRING
# LOCAL:      dev   (usa defaults sensatos, sin restricciones de producción)
# PRODUCCIÓN: prod  (requiere TODAS las vars; el servicio falla sin ellas)
# ------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev


# ------------------------------------------------------------
# BASE DE DATOS — Supabase (PostgreSQL)
#
# LOCAL: usa Direct Connection puerto 5432
#   jdbc:postgresql://db.<REF>.supabase.co:5432/postgres?sslmode=require
#
# PRODUCCIÓN: usa Transaction Pooler puerto 6543 (pgBouncer)
#   jdbc:postgresql://aws-0-<region>.pooler.supabase.co:6543/postgres?sslmode=require
#
# Obtener en: Supabase → tu proyecto → Settings → Database → Connection string
# ------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<COMPLETAR>


# ------------------------------------------------------------
# CLAVES RSA — firma de JWT
#
# Genera el par ejecutando los comandos del SETUP.md (Paso 3).
# LOCAL: si se dejan vacías, el servicio genera el par automáticamente
#        en disco (~/.auth-service/keys/) — cómodo para desarrollo.
# PRODUCCIÓN: OBLIGATORIO definirlas — el filesystem de contenedores es efímero.
# ------------------------------------------------------------
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=


# ------------------------------------------------------------
# JWT
# LOCAL:      http://localhost:8081
# PRODUCCIÓN: https://auth.tu-dominio.com  (HTTPS obligatorio)
# ------------------------------------------------------------
JWT_ISSUER=http://localhost:8081
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_MINUTES=60


# ------------------------------------------------------------
# CORS — orígenes del frontend permitidos (separados por coma)
# LOCAL:      puertos de desarrollo
# PRODUCCIÓN: solo dominios HTTPS reales
# ------------------------------------------------------------
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:8080


# ------------------------------------------------------------
# BLOQUEO DE CUENTA
# ------------------------------------------------------------
LOCKOUT_MAX_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=30


# ------------------------------------------------------------
# GOOGLE OAUTH2 (opcional para local)
# Obtener en: console.cloud.google.com → APIs & Services → Credentials
# Crear OAuth 2.0 Client ID tipo "Web application"
# Dejar vacío si no necesitas probar Google OAuth ahora
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=


# ------------------------------------------------------------
# EMAIL — SMTP
#
# OPCIÓN A — Mailtrap (recomendado para LOCAL / testing):
#   Captura los emails sin enviarlos; perfecta para desarrollo
#   Registrarse: mailtrap.io → tu inbox → SMTP Settings → credenciales
#   Host: sandbox.smtp.mailtrap.io  Puerto: 2525
#
# OPCIÓN B — AWS SES (recomendado para PRODUCCIÓN):
#   AWS Console → SES → SMTP Settings → Create SMTP credentials
#   Host: email-smtp.us-east-1.amazonaws.com  Puerto: 587
#   Verificar dominio/email remitente antes de usar
#
# OPCIÓN C — Gmail (pruebas rápidas):
#   Host: smtp.gmail.com  Puerto: 587
#   Password: App Password (Google Account → Security → App Passwords)
# ------------------------------------------------------------
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=<COMPLETAR>
MAIL_PASSWORD=<COMPLETAR>
MAIL_FROM=noreply@tu-dominio.com

# URL del servicio — incluida en los links del email de verificación
# LOCAL:      http://localhost:8081
# PRODUCCIÓN: https://auth.tu-dominio.com
MAIL_VERIFICATION_URL=http://localhost:8081/api/auth/verify-email

# URL del frontend para la pantalla de reset de contraseña
# LOCAL:      http://localhost:3000/reset-password
# PRODUCCIÓN: https://app.tu-dominio.com/reset-password
MAIL_RESET_URL=http://localhost:3000/reset-password
