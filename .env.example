# ============================================================
# AUTH SERVICE — Plantilla de variables de entorno
# ============================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Reemplaza todos los valores marcados con <REEMPLAZAR>
# 3. Nunca subas el archivo .env al repositorio
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS — MySQL
# ------------------------------------------------------------
MYSQL_ROOT_PASSWORD=<REEMPLAZAR>
MYSQL_DATABASE=auth_db
MYSQL_USER=auth_user
MYSQL_PASSWORD=<REEMPLAZAR>

SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/auth_db
SPRING_DATASOURCE_USERNAME=auth_user
SPRING_DATASOURCE_PASSWORD=<REEMPLAZAR>

# ------------------------------------------------------------
# JWT
# ------------------------------------------------------------
# En local: http://localhost:8081
# En producción: https://auth.tu-dominio.com
JWT_ISSUER=http://localhost:8081

# Duración del access token en minutos (recomendado: 15)
JWT_ACCESS_TTL_MINUTES=15

# Ventana de inactividad del refresh token en minutos (recomendado: 60)
JWT_REFRESH_TTL_MINUTES=60

# Directorio donde se guardan las claves RSA (no cambiar en Docker)
# JWT_KEYS_DIR=/home/spring/.auth-service/keys

# ------------------------------------------------------------
# CORS — Orígenes permitidos (separados por coma)
# ------------------------------------------------------------
# En local incluir todos los puertos que uses para desarrollo
# En producción incluir solo los dominios reales con HTTPS
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:8080

# ------------------------------------------------------------
# BLOQUEO DE CUENTA
# ------------------------------------------------------------
# Intentos fallidos antes de bloquear
LOCKOUT_MAX_ATTEMPTS=3

# Minutos que dura el bloqueo
LOCKOUT_DURATION_MINUTES=30

# ------------------------------------------------------------
# GOOGLE OAUTH2 (Option B — Token Exchange)
# ------------------------------------------------------------
# Obtener en: https://console.cloud.google.com → APIs & Services → Credentials
# Crear un OAuth 2.0 Client ID (tipo "Web application" para Angular,
# o el bundle ID de tu app para Flutter/Android/iOS)
GOOGLE_CLIENT_ID=<REEMPLAZAR>.apps.googleusercontent.com

# ------------------------------------------------------------
# EMAIL — AWS SES (o cualquier servidor SMTP)
# ------------------------------------------------------------
# AWS SES: activar en https://console.aws.amazon.com/ses
# Crear SMTP credentials en IAM → SES → SMTP Settings
MAIL_HOST=email-smtp.us-east-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=<REEMPLAZAR>
MAIL_PASSWORD=<REEMPLAZAR>
MAIL_FROM=noreply@tu-dominio.com

# URL base donde el servicio está expuesto (para los links de los emails)
# En local: http://localhost:8081
# En producción: https://auth.tu-dominio.com
MAIL_VERIFICATION_URL=http://localhost:8081/api/auth/verify-email

# URL del frontend donde está la pantalla de reset de contraseña
# En local: http://localhost:4200 (Angular) o http://localhost:3000
# En producción: https://app.tu-dominio.com/reset-password
MAIL_RESET_URL=http://localhost:3000/reset-password
